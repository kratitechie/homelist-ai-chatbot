}
.homie-msg.user {
  background: linear-gradient(135deg, #e67e22, #d35400);
  color: #fff;
  border-bottom-right-radius: 4px;
  align-self: flex-end;
}
.homie-typing {
  display: flex; gap: 4px; align-items: center;
  padding: 10px 14px;
  background: #fff;
  border-radius: 16px;
  border-bottom-left-radius: 4px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.08);
  align-self: flex-start;
  width: fit-content;
}
.homie-typing span {
  width: 7px; height: 7px;
  background: #aaa;
  border-radius: 50%;
  animation: homie-bounce 1.2s infinite;
}
.homie-typing span:nth-child(2) { animation-delay: 0.2s; }
.homie-typing span:nth-child(3) { animation-delay: 0.4s; }
@keyframes homie-bounce {
  0%, 60%, 100% { transform: translateY(0); }
