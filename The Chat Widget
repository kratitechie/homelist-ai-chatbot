}

#homie-input-area {
  padding: 12px;
  border-top: 1px solid #eee;
  display: flex;
  gap: 8px;
  background: #fff;
}
#homie-input {
  flex: 1;
  border: 1.5px solid #e0e0e0;
  border-radius: 24px;
